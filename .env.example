# ── Server ────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do NOT set it manually on Railway
PORT=5001
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────
# Generate strong random values, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_strong_random_string
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_different_strong_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Firebase / Firestore ──────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private_key value from the JSON file — keep the \n escapes
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----\n"

# ── CORS (web clients only — mobile apps are unaffected) ──────────────────
# Comma-separated list of allowed web origins
# In production add your deployed web app URL, e.g. https://bayit.vercel.app
CORS_ORIGIN=http://localhost:5173

# ── Email / Password Reset (optional) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
# Use a Gmail App Password (not your account password)
SMTP_PASS=your_gmail_app_password
# Full URL shown in the reset-password email link
FRONTEND_URL=http://localhost:5173
