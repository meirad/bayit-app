# ── Production (Railway) ────────────────────────────────────────────────────
# After deploying to Railway, paste your Railway URL here:
# EXPO_PUBLIC_API_BASE_URL=https://your-app.up.railway.app/api

# ── Local development ───────────────────────────────────────────────────────
# Android emulator (host machine localhost)
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:5001/api

# Physical device on same WiFi — replace with your Mac's local IP (run: ipconfig getifaddr en0)
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:5001/api
